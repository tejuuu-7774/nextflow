{
  "compilerOptions": {
    "target": "ES2020",

    "module": "Node16",          
    "moduleResolution": "Node16",

    "rootDir": ".",
    "outDir": "./dist",

    "esModuleInterop": true,
    "strict": true,

    "resolveJsonModule": true,
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0"
  }
}