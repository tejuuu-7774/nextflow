generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Workflow {
  id        String   @id @default(uuid())
  name      String
  nodes     Json
  edges     Json
  createdAt DateTime @default(now())

  runs      WorkflowRun[]
}

model WorkflowRun {
  id          String   @id @default(uuid())
  workflowId  String
  status      String
  duration    Int
  createdAt   DateTime @default(now())

  workflow    Workflow @relation(fields: [workflowId], references: [id])
  executions  NodeExecution[]
}

model NodeExecution {
  id        String   @id @default(uuid())
  runId     String
  nodeId    String
  type      String
  status    String
  output    String?
  startedAt DateTime
  endedAt   DateTime

  run       WorkflowRun @relation(fields: [runId], references: [id])
}